# Environment Variables Example
# Copy this file to .env.local and fill in your values

# Site URL (for metadata and SEO)
NEXT_PUBLIC_SITE_URL=https://ades-rdc.org

# Contact Form (optional - for production email integration)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# CONTACT_EMAIL=info@ades-rdc.org

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=

# Map Integration (optional)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
